# Frontend -> backend base URL (used for both HTTP and WebSocket)
REACT_APP_BACKEND_URL=https://wiz-app-production.up.railway.app

# Frontend public URL (exported from one central frontend config file)
REACT_APP_FRONTEND_URL=https://wiz-app.up.railway.app

# Backend CORS allow-list entry for deployed frontend URL
FRONT_END_URL=https://wiz-app.up.railway.app
